# Copia este archivo a .env.local y completa los valores de tu proyecto Supabase
# (Project Settings → API en https://supabase.com/dashboard).

# URL del proyecto, ej: https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_URL=

# Clave pública "anon" — segura de exponer al navegador, queda sujeta a RLS.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Clave "service_role" — NUNCA exponer al cliente. Hace bypass de RLS.
# Solo se usa en servidor (src/lib/supabase/admin.ts), para el panel /admin.
SUPABASE_SERVICE_ROLE_KEY=

# URL pública del sitio en producción (usada para generar enlaces de compartir del daily challenge).
NEXT_PUBLIC_SITE_URL=http://localhost:3000
